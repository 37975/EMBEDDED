// ═══════════════════════════════════════════════════════════
// Core 1 (UI & Hardware Updates)
// ═══════════════════════════════════════════════════════════
void updateOLED() {
  display.clearDisplay();

  int currentModeCopy = 1;
  int fanSpeedCopy = 0;
  int pm25Copy = 0;

  // 🟢 จุดแก้ไขสำคัญ: ป้องกันการไปเผลอตั้งค่ากลับเป็นเริ่มต้น
  if (xSemaphoreTake(dataMutex, portMAX_DELAY)) {
    currentModeCopy = mode;
    fanSpeedCopy = data.fanSpeed;
    pm25Copy = data.pm25;
    xSemaphoreGive(dataMutex);
  }

  int fanPercent = 0;
  if (currentModeCopy == 1) { 
      // โหมด Auto: จำลองการคำนวณ PWM จาก PM2.5 ด้วยสมการเดียวกับ Receiver
      float t = constrain(pm25Copy, 0, 150) / 150.0f;
      float curve = t * t;
      int autoPWM = constrain((int)(100 + curve * (255 - 100)), 100, 255);
      fanPercent = map(autoPWM, 100, 255, 1, 100);
  } else {
      // โหมด Manual: ใช้ค่าจากการบิด Potentiometer
      fanPercent = map(fanSpeedCopy, 100, 255, 1, 100);
  }
  
  fanPercent = constrain(fanPercent, 1, 100);

  if (currentModeCopy == 1) {
    display.drawBitmap(0, 0, AutoDisplay, 128, 64, SH110X_WHITE);
    display.setTextSize(1);
    display.setTextColor(SH110X_WHITE);
    //display PM 2.5
    display.setTextSize(2);
    display.setCursor(60, 20);
    display.print(pm25Copy);
    //display
    display.setTextSize(1);
    display.setCursor(5, 45);
    display.print("Speed");
    display.setCursor(35, 50);
    display.printf("%d%%", fanPercent);
    display.setCursor(5, 45);
  } else {
    display.drawBitmap(0, 0, ManualDisplay, 128, 64, SH110X_WHITE);
    display.setTextSize(2);
    display.setTextColor(SH110X_WHITE);
    display.setCursor(70, 20);
    display.printf("%d%%", fanPercent);
    display.setTextSize(1);
    display.setCursor(4, 44);
    display.print("PM2.5");
    display.setCursor(7, 53);
    display.print(lastPM25+String("ug/m^3"));
  }
  display.setTextSize(1);
  display.setCursor(74, 45);
  display.print(WiFi.status() == WL_CONNECTED ? "W -> C" : "W -> X");
  display.setCursor(74, 55);
  display.print(Firebase.ready() ? "FB-> C" : "FB -> X");

  display.display();
}

void IRAM_ATTR onSleepBtn() {
  unsigned long now = millis();
  if (now > 2000 && now - lastSleepPress > 600) {
    sleepRequested = true;
    lastSleepPress = now;
  }
}

void setupRGB() {
  pinMode(LED_R, OUTPUT); digitalWrite(LED_R, LED_OFF);
  pinMode(LED_G, OUTPUT); digitalWrite(LED_G, LED_OFF);
  pinMode(LED_B, OUTPUT); digitalWrite(LED_B, LED_OFF);
}

void setRGB(bool r, bool g, bool b) {
  digitalWrite(LED_R, r ? LED_ON : LED_OFF);
  digitalWrite(LED_G, g ? LED_ON : LED_OFF);
  digitalWrite(LED_B, b ? LED_ON : LED_OFF);
}

void updateLED(int pm25, int m) {
  if      (m == 0)   setRGB(0, 0, 0);
  else if (pm25 < 12)  setRGB(0, 1, 0);
  else if (pm25 < 35)  setRGB(1, 1, 0);
  else if (pm25 < 75)  setRGB(1, 1, 0);
  else if (pm25 < 150) setRGB(1, 0, 0);
  else               setRGB(1, 0, 1);
}

int readPot() {
  return analogRead(POT_PIN);
}

void setupUART() {
  uart_config_t cfg = {
    .baud_rate  = 9600,
    .data_bits  = UART_DATA_8_BITS,
    .parity     = UART_PARITY_DISABLE,
    .stop_bits  = UART_STOP_BITS_1,
    .flow_ctrl  = UART_HW_FLOWCTRL_DISABLE
  };
  uart_param_config(UART_PORT, &cfg);
  uart_set_pin(UART_PORT, TX_PIN, RX_PIN, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE);
  uart_driver_install(UART_PORT, 1024, 0, 0, NULL, 0);
}

int readPM() {
  uint8_t buffer[32];
  int len = uart_read_bytes(UART_PORT, buffer, 32, 20 / portTICK_PERIOD_MS);
  
  // 🟢 จุดแก้ไขสำคัญ: ป้องกันค่าขยะ ถ้าอ่านมาได้ไม่ครบ 32 ไบต์ให้เคลียร์ทิ้ง
  if (len == 32 && buffer[0] == 0x42 && buffer[1] == 0x4D) {
    lastPM10 = buffer[10] * 256 + buffer[11];
    return buffer[12] * 256 + buffer[13];
  } else if (len > 0) {
    uart_flush_input(UART_PORT); // ล้างข้อมูลตกค้างเพื่อเริ่มรับรอบใหม่
  }
  return -1;
}

// ═══════════════════════════════════════════════════════════
// Core 0 (Communications & Background Tasks)
// ═══════════════════════════════════════════════════════════
void initESPNow() {
  esp_now_deinit();
  delay(20);
  if (esp_now_init() != ESP_OK) {
    Serial.println("[ESP-NOW] init failed"); return;
  }
  if (!esp_now_is_peer_exist(receiverAddress)) {
    esp_now_peer_info_t peer = {};
    memcpy(peer.peer_addr, receiverAddress, 6);
    peer.channel = 0;
    peer.encrypt = false;
    esp_now_add_peer(&peer);
  }
  Serial.println("[ESP-NOW] ✓ ready");
}

void resyncWiFiChannel() {
  Serial.print("[WAKE] Resyncing WiFi channel");
  WiFi.disconnect();
  delay(100);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  unsigned long t0 = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - t0 < 8000) {
    Serial.print(".");
    delay(300);
  }
  if (WiFi.status() == WL_CONNECTED) {
    uint8_t ch; wifi_second_chan_t second;
    esp_wifi_get_channel(&ch, &second);
    Serial.printf("\n[WAKE] ✓ WiFi OK — channel: %d\n", ch);
  } else {
    Serial.println("\n[WAKE] ✗ WiFi reconnect failed");
  }
  initESPNow();
}

long long getTimestampMs() {
  struct tm t;
  if (!getLocalTime(&t)) return (long long)millis();
  return (long long)mktime(&t) * 1000LL;
}

void sendSensorData(int pm25_val, int pm10_val, String mode_val) {
  if (!Firebase.ready()) return;
  
  FirebaseJson json;
  json.set("pm25",      pm25_val);
  json.set("pm10",      pm10_val);
  json.set("mode",      mode_val);
  json.set("node_id",   NODE_ID);
  json.set("timestamp", getTimestampMs());
  if (Firebase.RTDB.setJSON(&fbdo, PATH_LATEST, &json)) {
    Serial.printf("[Firebase] ✓ pm25=%d mode=%s\n", pm25_val, mode_val.c_str());
  }
  
  if (millis() - lastHistory >= 30000) {
    lastHistory = millis();
    Firebase.RTDB.pushJSON(&fbdo, PATH_HISTORY, &json);
  }
}

void commsTask(void *pvParameters) {
  for (;;) {
    if (pauseComms) {
      commsIsPaused = true;
      vTaskDelay(50 / portTICK_PERIOD_MS);
      continue; 
    }
    commsIsPaused = false;

    Message localData;
    int localPM25, localPM10;
    int localMode;
    if (xSemaphoreTake(dataMutex, portMAX_DELAY)) {
      localData = data;
      localPM25 = lastPM25;
      localPM10 = lastPM10;
      localMode = mode;
      xSemaphoreGive(dataMutex);
    }

    esp_now_send(receiverAddress, (uint8_t*)&localData, sizeof(localData));

    unsigned long now = millis();
    if (now - lastSend >= 5000) {
      lastSend = now;
      String modeStr = (localMode == 1) ? "auto" : "manual";
      sendSensorData(localPM25, localPM10, modeStr);
      
      Serial.println("─────────────────────────────");
      Serial.printf("  MODE  : %s\n",       modeStr.c_str());
      Serial.printf("  PM2.5 : %d µg/m³\n", localPM25);
      Serial.printf("  PM10  : %d µg/m³\n", localPM10);
      Serial.println("─────────────────────────────");
    }

    vTaskDelay(200 / portTICK_PERIOD_MS);
  }
}

