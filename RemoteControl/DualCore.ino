// ═══════════════════════════════════════════════════════════
// SLEEP / WAKE Logic (Core 1)
// ═══════════════════════════════════════════════════════════
void enterSleep() {
  Serial.println("[SLEEP] Preparing...");
  OLEDSleep();
  if (xSemaphoreTake(dataMutex, portMAX_DELAY)) {
    data.type = 1;
    strcpy(data.cmd, "sleep");
    Serial.print("++++++++++Sending Sleep Cmd++++++++++");
    data.fanSpeed = 100;
    xSemaphoreGive(dataMutex);
  }

  for (int i = 0; i < 3; i++) {
    esp_now_send(receiverAddress, (uint8_t*)&data, sizeof(data));
    delay(50);
  }

  detachInterrupt(digitalPinToInterrupt(BTN_SLEEP));
  detachInterrupt(digitalPinToInterrupt(BTN_MODE));
  setRGB(0,0,0);

  pauseComms = true;
  unsigned long waitStart = millis();
  while (!commsIsPaused && (millis() - waitStart < 1000)) { 
    delay(10); 
  }
  Serial.println("[SLEEP] CommsTask Parked Safely");
  esp_now_deinit();
  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  Serial.println("[SLEEP Wifi Off] Zzz...");
  delay(200);

  while (digitalRead(BTN_SLEEP) == LOW) { delay(10); }
  delay(200);

  esp_sleep_enable_ext0_wakeup((gpio_num_t)BTN_SLEEP, 0);
  Serial.flush();
  esp_light_sleep_start();

  // --- WAKE ---
  Serial.println("[WAKE] Good morning!");
  setupRGB();
  OLEDWeakUp();
  delay(300);

  sleepRequested = false;
  
  if (xSemaphoreTake(dataMutex, portMAX_DELAY)) {
    mode           = 1;
    prevMode       = -1;
    xSemaphoreGive(dataMutex);
  }

  WiFi.mode(WIFI_STA);
  resyncWiFiChannel(); 
  delay(100);

  pauseComms = false;
  Serial.println("[WAKE] CommsTask Resumed");
  
  Message wakeCmd;
  wakeCmd.type = 1;
  strcpy(wakeCmd.cmd, "auto");
  wakeCmd.fanSpeed = 0;
  for (int i = 0; i < 5; i++) {
    esp_now_send(receiverAddress, (uint8_t*)&wakeCmd, sizeof(wakeCmd));
    delay(50);
  }
  
  attachInterrupt(digitalPinToInterrupt(BTN_SLEEP), onSleepBtn, FALLING);
}

// ═══════════════════════════════════════════════════════════
// SETUP & LOOP (Core 1)
// ═══════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  dataMutex = xSemaphoreCreateMutex();

  delay(250);
  display.begin(i2c_Address, true);
  display.clearDisplay();
  display.setRotation(0);
  
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0, 0);
  display.println("System Initializing...");
  display.display();

  Serial.printf("\n=== INDOOR [%s] ===\n", NODE_ID);

  pinMode(BTN_SLEEP, INPUT_PULLUP);
  pinMode(BTN_MODE,  INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(BTN_SLEEP), onSleepBtn, FALLING);

  setupRGB();
  setRGB(1,0,0); delay(400);
  setRGB(0,1,0); delay(400);
  setRGB(0,0,1); delay(400);
  setRGB(0,0,0);

  // --- 1. เช็คสถานะ WiFi ---
  display.print("WiFi: "); display.display();
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("WiFi");
  unsigned long t0 = millis();
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print("."); delay(300);
    if (millis() - t0 > 15000) { 
      Serial.println("\n✗ WiFi FAILED"); 
      break;
    }
  }
  if (WiFi.status() == WL_CONNECTED) {
    uint8_t ch; wifi_second_chan_t second;
    esp_wifi_get_channel(&ch, &second);
    Serial.printf("\n✓ IP: %s | Channel: %d\n", WiFi.localIP().toString().c_str(), ch);
    display.println("OK");
  } else {
    display.println("FAIL");
  }
  display.display();
  
  // --- 2. เช็คสถานะ ESP-NOW ---
  initESPNow();
  display.println("ESP-NOW: Ready"); 
  display.display();

  // --- 3. เช็คสถานะ NTP ---
  display.print("NTP: ");
  display.display();
  configTime(25200, 0, "pool.ntp.org", "time.google.com");
  Serial.print("NTP");
  {
    struct tm t;
    unsigned long t0_ntp = millis();
    while (!getLocalTime(&t) && millis() - t0_ntp < 10000) { Serial.print("."); delay(500); }
    char buf[32] = "timeout";
    if (getLocalTime(&t)) {
        strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &t);
        display.println("OK");
    } else {
        display.println("FAIL");
    }
    Serial.printf("\n✓ %s (GMT+7)\n", buf);
  }
  display.display();

  // --- 4. เช็คสถานะ Firebase ---
  display.print("Firebase: "); display.display();
  config.database_url = FIREBASE_HOST;
  config.signer.tokens.legacy_token = FIREBASE_SECRET;
  config.token_status_callback = tokenStatusCallback;
  Firebase.begin(&config, &auth);
  Firebase.reconnectNetwork(true);
  Serial.print("Firebase");
  {
    unsigned long t0_fb = millis();
    while (!Firebase.ready() && millis() - t0_fb < 10000) { Serial.print("."); delay(300); }
  }
  if(Firebase.ready()) {
      display.println("OK");
  } else {
      display.println("FAIL");
  }
  Serial.printf("\n%s\n", Firebase.ready() ? "✓ ready" : "✗ timeout");
  display.display();

  delay(1500); 

  setupUART();
  if (xSemaphoreTake(dataMutex, portMAX_DELAY)) {
    mode = 1;
    prevMode = -1; 
    data.type = 1;
    strcpy(data.cmd, "auto"); 
    data.pm25 = 0;
    data.fanSpeed = 0;
    xSemaphoreGive(dataMutex);
  }
  xTaskCreatePinnedToCore(
    commsTask,       
    "CommsTask",     
    16384,           
    NULL,            
    1,               
    &CommsTaskHandle,
    0              
  );
  Serial.println("=== RUNNING DUAL CORE ===");
}


void loop() {
  if (sleepRequested) {
    if (millis() - lastSleepPress < 1000) {
      enterSleep();
    } else {
      sleepRequested = false;
    }
    return;
  }

  int tempMode = mode;
  int tempFanSpeed = lastPotFanSpeed;
  int tempPM25 = lastPM25;

  // 🟢 จุดแก้ไขสำคัญ: ปรับปรุงการกดปุ่มให้แม่นยำขึ้นแบบไม่ต้องใช้ Delay ขัดจังหวะ
  static unsigned long lastBtnTime = 0;
  bool btnMode = digitalRead(BTN_MODE);
  if (lastBtnMode == HIGH && btnMode == LOW && millis() - lastBtnTime > 250) {
    tempMode = (tempMode == 1) ? 2 : 1;
    lastBtnTime = millis();
    Serial.printf("[BUTTON] Switched Mode to: %d\n", tempMode);
  }
  lastBtnMode = btnMode;

  int pm = readPM();
  if (pm > 0) tempPM25 = pm;
  
  if (tempMode == 2) {
    tempFanSpeed = map(readPot(), 0, 4095, 100, 255);
  }

  if (xSemaphoreTake(dataMutex, portMAX_DELAY)) {
    mode = tempMode;
    lastPM25 = tempPM25;
    lastPotFanSpeed = tempFanSpeed;
    
    if (mode != prevMode) {
      data.type = 1;
      strcpy(data.cmd, mode == 1 ? "auto" : "manual");
      prevMode = mode;
      modeChangeSendCount = 5;
    } else if (modeChangeSendCount > 0) {
      data.type = 1;
      modeChangeSendCount--;
    } else {
      data.type = 0;
      strcpy(data.cmd, "");
    } 
    
    data.pm25 = lastPM25;
    data.fanSpeed = lastPotFanSpeed;
    
    xSemaphoreGive(dataMutex);
  }

  updateLED(tempPM25, tempMode);
  updateOLED();

  delay(50); 
}